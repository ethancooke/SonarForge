<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- REQUIRED under the hardened runtime: without this, the Core Audio tap
         silently delivers zeros in Release builds (Debug builds mask it because
         debuggable builds relax hardened-runtime enforcement). Verified
         empirically 2026-06-11 — do not remove. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
